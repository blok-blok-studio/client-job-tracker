# Database
DATABASE_URL="postgresql://user:password@localhost:5432/blokblok_command"

# Authentication
AUTH_PASSWORD_HASH="$2b$12$..."  # Run: npx tsx scripts/hash-password.ts YOUR_PASSWORD
AUTH_SECRET="generate-a-64-char-random-string"

# Encryption (CRITICAL: generate strong random values)
# Run: npx tsx scripts/generate-secrets.ts
ENCRYPTION_MASTER_KEY="generate-a-64-char-hex-string"
ENCRYPTION_SALT="generate-a-32-char-hex-string"

# Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# OpenClaw
OPENCLAW_API_URL="http://your-openclaw-host:port/api"
OPENCLAW_API_TOKEN="your-openclaw-api-token"
OPENCLAW_WEBHOOK_SECRET="generate-a-random-string"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your-bot-username"  # Used for onboarding Telegram deep links (t.me/bot?start=token)

# Telegram Admin — messages from this chat go to Cortana command mode (not support tickets)
# Get your chat ID by texting /start to the bot and checking server logs
ADMIN_TELEGRAM_CHAT_ID=""
# Fallback: match by Telegram username (without @)
ADMIN_TELEGRAM_USERNAME=""

# Cron (for Vercel)
CRON_SECRET="generate-a-random-string"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
